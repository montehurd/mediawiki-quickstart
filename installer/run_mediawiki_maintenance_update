#!/bin/bash

source "/var/local/common/utility.sh"

set -eu

run_mediawiki_maintenance_update() {
  php maintenance/run.php update --quick 2>&1 | verboseOrDotPerLine "Mediawiki maintenance update"
  # Check update.php's own status - the pipeline's status is
  # verboseOrDotPerLine's, which always succeeds
  if [ "${PIPESTATUS[0]}" -ne 0 ]; then
    echo "PHP maintenance update failed. Exiting"
    return 1
  fi
  return 0
}

if [[ "$0" == "${BASH_SOURCE[0]}" ]]; then
  run_mediawiki_maintenance_update "$@"
fi
